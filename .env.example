# ============================================
# CONFIGURACIÓN API DE LICENCIAS
# ============================================

# Entorno: development | production
FLASK_ENV=production

# Clave secreta (generar una segura)
SECRET_KEY=tu-clave-secreta-muy-larga-aqui-minimo-32-caracteres

# Base de datos PostgreSQL (Render proporciona esto)
# Formato: postgresql://usuario:password@host:puerto/database
DATABASE_URL=postgresql://usuario:password@localhost:5432/licencias_db

# Puerto (Render usa variable PORT)
PORT=5001

# Configuración de seguridad
REQUIRE_HTTPS=true

# Período de gracia por defecto (horas)
GRACE_PERIOD_HOURS=24

# URLs de retorno (para el panel admin)
FRONTEND_URL=http://localhost:3000
